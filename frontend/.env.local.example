NEXT_PUBLIC_API_URL=http://localhost:8000

# EmailJS (optional - email export hidden when not configured)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# Mapbox (W2: required for The Wall map render). Create a token at
# https://account.mapbox.com/access-tokens/ — public tokens start with `pk.`.
# When unset, W2's WallContainer falls back to a static branded placeholder
# (T1.74). T1.6's validateMapboxToken() reads this at boot; T2.1's
# isMapboxAvailable() additionally probes the CDN with a 2s timeout.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# Mapbox custom dark editorial style (W2 T2.18). Build the style once in
# Mapbox Studio (see docs/runbooks/mapbox-style-setup.md) and paste the
# resulting URI here. When unset, MapboxScene falls back to the stock
# `mapbox://styles/mapbox/dark-v11`. URIs MUST start with `mapbox://styles/`
# — anything else is rejected as a URL-spoofing defense.
NEXT_PUBLIC_MAPBOX_STYLE_URL=mapbox://styles/your-account/wall-dark-editorial-v1
