# Trello (required for trello sync)
TRELLO_API_KEY=
TRELLO_TOKEN=

# GitHub (required for auto-PR)
GITHUB_TOKEN=

# Feature flags (resolution order: env > config/feature_flags.yaml > default)
# Gate for S12b AI generation (resume/cover letter). Keep false until a
# data processing agreement is in place.
ENABLE_AI_GENERATION=false
# Master switch for the nightly scheduler job.
FEATURE_NIGHTLY_ENABLED=true
# Master switch for outbound email delivery.
FEATURE_EMAIL_SEND_ENABLED=true

# SendGrid (T12.2) — Mail Send scope ONLY.
# When generating the key in the SendGrid UI, choose Restricted Access and
# enable only "Mail Send -> Full Access". Do NOT grant Contact lists,
# Sender Authentication management, or Email Activity read permissions.
# See docs/ops/sendgrid-setup.md for the full setup + rotation runbook.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

