# ---------------------------------------------------------------------------
# MontGoWork — example environment file (T13.118 production env audit)
#
# Copy to `.env` (gitignored) and fill in real values for local dev. For
# staging/production secrets, set them via `fly secrets set` (see
# `docs/runbooks/staging-deploy.md` §3.4 for the canonical secrets table).
#
# Convention: each entry below has a comment with
#   <description> — required|optional — <default if any>
# followed by `KEY=` (or `KEY=example-value` for non-secret config).
# Required vars are validated at boot by `app.core.env_validation`
# (`backend/app/core/env_validation.py`); the app refuses to start if any
# are missing.
#
# Cross-references:
# - `backend/app/core/config.py` (Settings class — pydantic-settings reads
#   these by lowercased name).
# - `docs/runbooks/staging-deploy.md` §2.3 (production secrets table).
# - `deploy/fly/fly.backend.toml` `[env]` (non-secret env baked into deploy).
# ---------------------------------------------------------------------------

# ============================================================================
# 1. App configuration (required-on-boot or has hard-coded defaults)
# ============================================================================

# Deploy environment: development | test | staging | production.
# Drives `_is_production` gates (HSTS, /docs disable, strict salt + key
# validators, CORS lockdown). — optional — default: development
ENVIRONMENT=development

# SQLAlchemy DSN. Required-on-boot. The Fly deploy injects
# `sqlite+aiosqlite:////app/data/montgowork.db`. — required
DATABASE_URL=sqlite+aiosqlite:///./montgowork.db

# Admin API key for `/api/admin/*` endpoints (X-Admin-Key header).
# Required-on-boot. Production validator additionally enforces >=32 chars.
# Generate: `python -c "import secrets; print(secrets.token_urlsafe(32))"`
# — required
ADMIN_API_KEY=

# Salt for SHA256 audit-trail hashing (session ids, AI request hashes).
# Required-on-boot. Production validator rejects the literal default
# `montgowork-default-salt`.
# Generate: `python -c "import secrets; print(secrets.token_urlsafe(24))"`
# — required
AUDIT_HASH_SALT=

# Comma-separated list of allowed CORS origins. Production validator
# rejects any value containing `localhost`. — optional — default:
# http://localhost:3000,http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Comma-separated list of trusted proxy hosts for ProxyHeadersMiddleware
# (X-Forwarded-* parsing). Use `*` only behind a known reverse proxy
# (the Fly deploy uses `*` because Fly's edge is the only ingress).
# — optional — default: 127.0.0.1
TRUSTED_PROXY_HOSTS=127.0.0.1

# Active city slug; loads `cities/<slug>.yaml`. Validated against
# `^[a-z][a-z0-9-]{0,49}$`. — optional — default: montgomery
CITY=montgomery

# Override base data directory (city + barrier graph fixtures). Empty
# falls through to repo-relative defaults. — optional — default: ""
DATA_DIR=

# Logging level; case-insensitive. — optional — default: INFO
LOG_LEVEL=INFO

# Optional sink for the AI/audit JSONL stream. Empty disables file sink.
# — optional — default: "" (no file sink)
AUDIT_LOG_PATH=

# Uvicorn worker count. The lifespan hard-fails if >1 because
# APScheduler is single-process; multi-worker rate limiting is also
# per-process. — optional — default: 1
WEB_CONCURRENCY=1

# ============================================================================
# 2. LLM providers (optional — at least one recommended in production)
# ============================================================================
# With none set, the app falls back to the mock provider (logs a warning
# at startup). The boot validator emits an "Optional environment
# variable ... missing — degraded mode" line for each unset key below.

# Active provider: anthropic | openai | gemini | mock.
# — optional — default: anthropic
LLM_PROVIDER=anthropic

# Anthropic Claude (default provider). — optional — default: ""
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI fallback. — optional — default: ""
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Google Gemini fallback. — optional — default: ""
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Master switch for resume + cover-letter LLM generation. Keep `false`
# until a data processing agreement is in place; the builders fall back
# to deterministic templates. — optional — default: false
ENABLE_AI_GENERATION=false

# ============================================================================
# 3. Outbound email — SendGrid (T12.10a appointments, T12.19 digest)
# ============================================================================
# When generating the SendGrid key, choose Restricted Access and enable
# only "Mail Send -> Full Access". Do NOT grant Contact lists, Sender
# Authentication management, or Email Activity read scopes. See
# `docs/ops/sendgrid-setup.md` for the rotation runbook.

# SendGrid Mail Send API key. — optional — default: ""
SENDGRID_API_KEY=

# Verified sender. Falls back to noreply@montgowork.local if unset (will
# fail SendGrid sender authentication). — optional — default:
# noreply@montgowork.local
SENDGRID_FROM_EMAIL=

# PEM-formatted ed25519 public key for SendGrid event-webhook signature
# verification. Empty disables signature verification (rejects all
# webhook posts in production). — optional — default: ""
SENDGRID_WEBHOOK_PUBLIC_KEY=

# Master switch for any outbound email send (kill switch). Disable to
# silence the reminder + digest pipelines without changing keys.
# — optional — default: true
FEATURE_EMAIL_SEND_ENABLED=true

# ============================================================================
# 4. Token signing secrets (rotatable; *_OLD allows overlap window)
# ============================================================================
# All three are HMAC-SHA256 secrets used by their respective signers.
# They have no boot-time default; the signing call sites raise at
# signing time when unset, so unset secrets do NOT block app startup
# (the boot validator warns instead).

# Signed appointment manage-link tokens (T12.10b). 7-day overlap
# window. Generate: `python -c "import secrets; print(secrets.token_urlsafe(32))"`
# — optional but required for appointment emails — default: ""
APPOINTMENT_TOKEN_SECRET=
APPOINTMENT_TOKEN_SECRET_OLD=

# Compliance export-link signer (T12.36). Generate same way.
# — optional but required for the data-export feature — default: ""
COMPLIANCE_TOKEN_SECRET=
COMPLIANCE_TOKEN_SECRET_OLD=

# Unsubscribe-link signer (CAN-SPAM compliance). Generate same way.
# — optional but required for any reminder/digest email — default: ""
UNSUBSCRIBE_TOKEN_SECRET=
UNSUBSCRIBE_TOKEN_SECRET_OLD=

# Public base URL used in templated emails (manage-link, unsubscribe).
# — optional — default: https://app.montgowork.local
APP_HOST=https://app.montgowork.local

# ============================================================================
# 5. Job-board integrations
# ============================================================================

# BrightData live-crawl credentials (S6/S7). Without both, the jobs
# panel falls back to seeded/static jobs. — optional — default: ""
BRIGHTDATA_API_KEY=
BRIGHTDATA_DATASET_ID=

# Comma-separated allowlist of job-board domains the crawler will hit.
# — optional — default: indeed.com
BRIGHTDATA_JOB_DOMAINS=indeed.com

# USAJobs.gov API (federal listings). Both required to enable USAJobs
# adapter; missing → adapter silently disabled. — optional — default: ""
USAJOBS_API_KEY=
USAJOBS_EMAIL=

# ============================================================================
# 6. Credit microservice (sibling app)
# ============================================================================

# Base URL for the optional credit-assessment service. Production
# validator rejects private/link-local IPs. — optional — default:
# http://localhost:8001
CREDIT_API_URL=http://localhost:8001
CREDIT_API_KEY=

# ============================================================================
# 7. Feature flags (env > config/feature_flags.yaml > default)
# ============================================================================
# Pattern: `FEATURE_<NAME>=true|false`. Read by app.core.feature_flags.

# Master switch for the nightly APScheduler job. — optional — default: true
FEATURE_NIGHTLY_ENABLED=true

# (See section 3 for FEATURE_EMAIL_SEND_ENABLED.)

# ============================================================================
# 8. Frontend (Next.js — process.env, prefixed NEXT_PUBLIC_ are bundled)
# ============================================================================
# These are read by the frontend build/runtime, not the backend. They
# are NOT validated by `validate_required_env`. Document here for
# completeness. The Fly deploy bakes `NEXT_PUBLIC_API_URL` at build
# time via `--build-arg` (see runbook §3.6).

# Public site URL — used for OG/Twitter metadataBase. — optional —
# default: https://montgowork.com
NEXT_PUBLIC_SITE_URL=https://montgowork.com

# Backend API base URL. — optional — default: http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# EmailJS (frontend export-by-email integration). All three required
# together to enable the feature. — optional — default: ""
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# ============================================================================
# 9. Trello + GitHub (developer tooling — not used by the app at runtime)
# ============================================================================

# Trello sync (`bpsai-pair trello *`). — optional — default: ""
TRELLO_API_KEY=
TRELLO_TOKEN=

# Auto-PR creation by bpsai-pair workflows. — optional — default: ""
GITHUB_TOKEN=

# ============================================================================
# 10. QC harness (T13.* — only set when running staging QC suites)
# ============================================================================
# Read by `.paircoder/qc/config.yaml` and `scripts/staging-smoke.sh`.
# Not used by the running app. Set in your QC shell or CI secret store.

# STAGING_FRONTEND_URL=https://montgowork-staging-web.fly.dev
# STAGING_BACKEND_URL=https://montgowork-staging-api.fly.dev
# STAGING_API_URL=https://montgowork-staging-api.fly.dev   # alias for STAGING_BACKEND_URL
# STAGING_ADMIN_KEY=
# STAGING_WORKER_MGM_SESSION=
# STAGING_WORKER_FTW_SESSION=
# STAGING_ADVISOR_MGM_TOKEN=
# STAGING_ADVISOR_FTW_TOKEN=
# MONTGOWORK_QC_ENV=dev   # dev | staging | prod
